{
  "name": "diffview",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "bun build src/index.ts --outfile dist/cli.js --minify --target=bun",
    "build:api": "bun --cwd apps/api build",
    "build:cli": "bun --cwd apps/cli build",
    "build:web": "bun --cwd apps/web build",
    "check": "bun run typecheck && oxlint && oxfmt apps/**/*.ts apps/**/*.tsx packages/**/*.ts packages/**/*.tsx",
    "dev": "bun run --bun apps/cli/src/index.ts",
    "start": "bun run --bun apps/cli/src/index.ts",
    "test": "echo \"Error: no test specified\" && exit 1",
    "typecheck": "bun --cwd apps/web typecheck && bun --cwd apps/api typecheck && bun --cwd apps/cli typecheck && bun --cwd packages/shared typecheck"
  },
  "dependencies": {
    "@pierre/diffs": "^1.1.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@typescript/native-preview": "^7.0.0-dev.20260322.1",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "typescript": "^6.0.0-beta"
  },
  "peerDependencies": {}
}
