{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "composite": true,
    "types": ["bun", "node"],
    "paths": {
      "*": ["./*"],
      "@diffview/shared": ["../packages/shared/src"]
    }
  },
  "include": ["src"]
}
